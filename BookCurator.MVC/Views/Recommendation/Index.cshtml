@model BookCurator.MVC.Models.ViewModels.RecommendationViewModel

<h2>Get a Recommendation</h2>
<p class="text-muted">Based on your @Model.ItemCount books.</p>

<form asp-action="Index" method="post" id="recForm">
    <div class="mb-3">
        <label class="form-label">In the mood for something specific? (optional)</label>
        <input asp-for="Mood" class="form-control" placeholder="e.g. something like Dune but shorter" />
    </div>
    <button type="submit" class="btn btn-primary" id="recBtn">Get Recommendation</button>
</form>

@if (!string.IsNullOrEmpty(Model.Result))
{
    <div class="alert alert-info mt-4">
        <strong>Recommendation:</strong>
        <p class="mb-0">@Model.Result</p>
    </div>
}

<script>
    document.getElementById('recForm').addEventListener('submit', function () {
        const btn = document.getElementById('recBtn');
        btn.disabled = true;
        btn.textContent = 'Thinking...';
    });
</script>
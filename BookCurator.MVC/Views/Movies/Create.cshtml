@model BookCurator.DAL.Entities.Movie

<h2>Add a Movie</h2>
<form asp-action="Create" method="post">
    <div class="mb-3">
        <label class="form-label">Title</label>
        <input asp-for="Title" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Director</label>
        <input asp-for="Director" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Genre</label>
        <input asp-for="Genre" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Status</label>
        <select asp-for="Status" asp-items="Html.GetEnumSelectList<BookCurator.DAL.Entities.WatchStatus>()" class="form-select"></select>
    </div>
    <div class="mb-3">
        <label class="form-label">Rating (1-5, optional)</label>
        <input asp-for="Rating" class="form-control" type="number" min="1" max="5" />
    </div>
    <div class="mb-3">
        <label class="form-label">Notes</label>
        <textarea asp-for="Notes" class="form-control"></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-link">Cancel</a>
</form>
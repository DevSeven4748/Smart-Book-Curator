@using BookCurator.DAL.Entities
@model IEnumerable<Movie>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Movie List</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add New Movie
    </a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Title</th>
            <th>Director</th>
            <th>Genre</th>
            <th>Status</th>
            <th>Rating</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var movie in Model)
        {
            <tr>
                <td><strong>@movie.Title</strong></td>
                <td>@movie.Director</td>
                <td>@movie.Genre</td>
                <td>
                    @{
                        var badgeClass = movie.Status switch
                        {
                            WatchStatus.Finished => "bg-success",
                            WatchStatus.Watching => "bg-warning text-dark",
                            _ => "bg-secondary"
                        };
                    }
                    <span class="badge @badgeClass">@movie.Status.ToString()</span>
                </td>
                <td>@(movie.Rating?.ToString() ?? "-") / 5</td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@movie.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@movie.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
